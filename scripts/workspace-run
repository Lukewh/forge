#!/usr/bin/env node
"use strict";

const fs = require("fs");
const path = require("path");
const { spawnSync } = require("child_process");

const FORGE_DIR = process.env.FORGE_DIR || path.resolve(__dirname, "..");
const CONFIG_PATH = path.join(FORGE_DIR, "workspace-run.config.json");

function usage(exitCode = 2) {
  const out = exitCode === 0 ? console.log : console.error;
  out(`Usage:\n  scripts/workspace-run <worktree-path> -- <command...>\n  scripts/workspace-run <worktree-path> "<command>"\n\nRuns project runtime commands in the configured workspace environment.\nConfig: ${CONFIG_PATH} (optional; defaults to local mode)`);
  process.exit(exitCode);
}

function shellQuote(value) {
  const s = String(value);
  if (s.length === 0) return "''";
  return `'${s.replace(/'/g, `'"'"'`)}'`;
}

function loadConfig() {
  if (!fs.existsSync(CONFIG_PATH)) return { mode: "local" };
  try {
    const parsed = JSON.parse(fs.readFileSync(CONFIG_PATH, "utf8"));
    return parsed && typeof parsed === "object" ? parsed : { mode: "local" };
  } catch (error) {
    console.error(`Invalid workspace-run config at ${CONFIG_PATH}: ${error.message}`);
    process.exit(2);
  }
}

function normalizePrefix(prefix) {
  return path.resolve(prefix).replace(/\/$/, "");
}

function translatePath(localPath, mappings = []) {
  const resolved = path.resolve(localPath);
  const matches = mappings
    .filter((mapping) => mapping && mapping.localPrefix && mapping.remotePrefix)
    .map((mapping) => ({
      localPrefix: normalizePrefix(mapping.localPrefix),
      remotePrefix: String(mapping.remotePrefix).replace(/\/$/, ""),
    }))
    .filter((mapping) => resolved === mapping.localPrefix || resolved.startsWith(`${mapping.localPrefix}${path.sep}`))
    .sort((a, b) => b.localPrefix.length - a.localPrefix.length);

  if (matches.length === 0) return null;
  const match = matches[0];
  const suffix = resolved.slice(match.localPrefix.length).split(path.sep).join("/");
  return `${match.remotePrefix}${suffix}`;
}

function commandFromArgs(args) {
  const sep = args.indexOf("--");
  if (sep >= 0) {
    const commandArgs = args.slice(sep + 1);
    if (commandArgs.length === 0) usage();
    return commandArgs.map(shellQuote).join(" ");
  }
  if (args.length === 1) return args[0];
  if (args.length > 1) return args.map(shellQuote).join(" ");
  usage();
}

function runLocal(worktreePath, command) {
  return spawnSync(command, {
    cwd: worktreePath,
    shell: true,
    stdio: "inherit",
    env: process.env,
  });
}

function runSsh(config, worktreePath, command) {
  const ssh = config.ssh || {};
  if (!ssh.target) {
    console.error("workspace-run ssh mode requires ssh.target in workspace-run.config.json");
    process.exit(2);
  }
  const remotePath = translatePath(worktreePath, ssh.pathMappings || []);
  if (!remotePath) {
    console.error(`No ssh.pathMappings entry matches worktree path: ${worktreePath}`);
    process.exit(2);
  }
  const remoteCommand = `cd ${shellQuote(remotePath)} && ${command}`;
  const sshArgs = Array.isArray(ssh.args) ? ssh.args : [];
  return spawnSync("ssh", [...sshArgs, ssh.target, remoteCommand], {
    stdio: "inherit",
    env: process.env,
  });
}

function main() {
  const args = process.argv.slice(2);
  if (args.includes("-h") || args.includes("--help")) usage(0);
  const worktreePath = args.shift();
  if (!worktreePath) usage();

  const resolvedWorktree = path.resolve(worktreePath);
  if (!fs.existsSync(resolvedWorktree)) {
    console.error(`Worktree path does not exist: ${resolvedWorktree}`);
    process.exit(2);
  }

  const command = commandFromArgs(args);
  const config = loadConfig();
  const mode = config.mode || "local";
  let result;

  if (mode === "local") result = runLocal(resolvedWorktree, command);
  else if (mode === "ssh") result = runSsh(config, resolvedWorktree, command);
  else {
    console.error(`Unsupported workspace-run mode: ${mode}`);
    process.exit(2);
  }

  if (result.error) {
    console.error(result.error.message);
    process.exit(1);
  }
  if (result.signal) process.kill(process.pid, result.signal);
  process.exit(result.status ?? 1);
}

main();
